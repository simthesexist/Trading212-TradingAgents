# ============================================
# T212 CONFIGURATION
# ============================================
# Mode: "demo" or "live"
T212_MODE=demo

# --- DEMO API KEYS ---
# Get from: https://demo.trading212.com → Settings → API
T212_DEMO_API_KEY=your_demo_api_key_here
T212_DEMO_API_SECRET=your_demo_api_secret_here

# --- LIVE API KEYS ---
# Get from: https://app.trading212.com → Settings → API
# Only supports Invest & Stocks ISA accounts
T212_LIVE_API_KEY=your_live_api_key_here
T212_LIVE_API_SECRET=your_live_api_secret_here

# ============================================
# TRADINGAGENTS / AI CONFIGURATION
# ============================================
# LLM Provider: openai, anthropic, google, deepseek
LLM_PROVIDER=anthropic
DEEP_THINK_LLM=claude-sonnet-4-7
QUICK_THINK_LLM=claude-haiku-4-5

# MiniMax Anthropic-compatible API (recommended for news sentiment)
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_API_KEY=your_minimax_api_key_here

# ============================================
# DATA PROVIDER
# ============================================
DATA_PROVIDER=yfinance  # yfinance (free, no key needed)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
POLYGON_API_KEY=

# ============================================
# TRADINGAGENTS EXECUTION SETTINGS
# ============================================
# Auto-execute trades? (false = manual review recommended)
AUTO_EXECUTE=false

# Minimum confidence to execute (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.7

# Allow SELL signals?
ALLOW_SELL=true