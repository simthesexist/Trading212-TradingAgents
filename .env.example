# T212 Configuration
T212_MODE=demo  # Set to "demo" or "live"
T212_API_KEY=your_api_key_here
T212_API_SECRET=your_api_secret_here

# LLM Configuration for TradingAgents
LLM_PROVIDER=anthropic
DEEP_THINK_LLM=claude-sonnet-4-7
QUICK_THINK_LLM=claude-haiku-4-5

# Data Provider
DATA_PROVIDER=yfinance  # yfinance or alphavantage
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# TradingAgents Integration
AUTO_EXECUTE=false          # true = auto execute, false = manual review
CONFIDENCE_THRESHOLD=0.7     # Min confidence to execute (0.0 to 1.0)
ALLOW_SELL=true              # Enable/disable SELL signals

# API Keys (based on LLM_PROVIDER)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here